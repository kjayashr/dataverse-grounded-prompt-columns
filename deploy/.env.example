DATAVERSE_URL=https://org406c2541.crm.dynamics.com
ACCOUNT_TOP=12
CORS_ORIGINS=*

# Live mode only: a client-credentials app registration that is also a
# Dataverse application user with a security role.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
